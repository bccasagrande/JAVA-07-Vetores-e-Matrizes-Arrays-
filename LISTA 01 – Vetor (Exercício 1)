algoritmo "buscar_no_vetor"

var
   vetor: vetor[10] de inteiro
   numero, i: inteiro
   encontrado: logico

inicio

   vetor[0] <- 2
   vetor[1] <- 5
   vetor[2] <- 1
   vetor[3] <- 3
   vetor[4] <- 4
   vetor[5] <- 9
   vetor[6] <- 7
   vetor[7] <- 8
   vetor[8] <- 10
   vetor[9] <- 6

   escreva("Digite o número que você deseja encontrar: ")
   leia(numero)

   encontrado <- falso

   para i de 0 ate 9 faca
      se vetor[i] = numero entao
         escreval("O número ", numero, " está localizado na posição: ", i)
         encontrado <- verdadeiro
      fimse
   fimpara

   se encontrado = falso entao
      escreval("O número ", numero, " não foi encontrado!")
   fimse

fimalgoritmo
